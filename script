local function btn(txt,y,k)
    local b = Instance.new("TextButton") b.Size = UDim2.new(1,-20,0,24) b.Position = UDim2.new(0,10,0,y) b.BackgroundColor3 = Color3.fromRGB(35,35,40) b.Text = txt..": OFF" b.TextColor3 = Color3.fromRGB(255,100,100) b.Font = Enum.Font.SourceSansBold b.TextSize = 9 b.Parent = CF
