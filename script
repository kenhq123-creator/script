-- KILL COUNTER
f.ChildRemoved:Connect(function() 
    if cfg.M then 
        cfg.Kills = cfg.Kills + 1 
        if CG:FindFirstChild("BlasterHubV4") then 
            local l = CG.BHubV4.MF.CF:FindFirstChild("KCL") 
            if l then l.Text = "ZOMBIES VAPORIZED: " .. cfg.Kills end 
        end 
    end 
end)

-- MAGNET
task.spawn(function() 
    while task.wait(0.05) do 
        if cfg.M then 
            pcall(function() 
                local c = LP.Character 
                local hrp = c and c:FindFirstChild("HumanoidRootPart") 
                if hrp and f then 
                    local pos = hrp.CFrame * CFrame.new(cfg.Side,0,-cfg.Dist) 
                    for _,m in pairs(f:GetChildren()) do 
                        local r = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Head") or m 
                        if r then 
                            if r:IsA("BasePart") then 
                                r.CFrame = pos 
                                r.Velocity = Vector3.new(0,0,0) 
                            elseif m:IsA("Model") then 
                                m:SetPrimaryPartCFrame(pos) 
                            end 
                        end 
                    end 
                end 
            end) 
        end 
    end 
end)

-- ESP
task.spawn(function() 
    while task.wait(0.5) do 
        pcall(function() 
            if f then 
                for _,m in pairs(f:GetChildren()) do 
                    if cfg.E then 
                        if not m:FindFirstChild("HL") then 
                            local hl = Instance.new("Highlight") hl.Name = "HL" hl.FillColor = Color3.fromRGB(255,50,50) hl.FillTransparency = 0.5 hl.Parent = m 
                        end 
                    else 
                        if m:FindFirstChild("HL") then m.HL:Destroy() end 
                    end 
                end 
            end 
        end) 
    end 
end)

-- STAFF DETECTION
task.spawn(function() 
    while task.wait(1) do 
        if cfg.AL then 
            pcall(function() 
                for _,p in pairs(P:GetPlayers()) do 
                    if p ~= LP and LP.Character and p.Character then 
                        local my = LP.Character:FindFirstChild("HumanoidRootPart") 
                        local th = p.Character:FindFirstChild("HumanoidRootPart") 
                        if my and th and (my.Position - th.Position).Magnitude < 50 then LP:Kick("Security!") end 
                    end 
                end 
            end) 
        end 
    end 
end)

-- SMART GUN UPGRADE
task.spawn(function() 
    while true do 
        task.wait(0.5) 
        if cfg.UW and RUW and Cash then 
